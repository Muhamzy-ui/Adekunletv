# Monorepo .gitignore

# Backend ignores
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/db.sqlite3
backend/.env
backend/staticfiles/
backend/media/

# Frontend ignores
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# General
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
